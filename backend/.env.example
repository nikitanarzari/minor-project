# Server
PORT=4000

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Blockchain (same deployer key as Hardhat deploy for local testing, or read-only is fine for view calls)
PRIVATE_KEY=
CONTRACT_ADDRESS=

# RPC — local Ganache default port 7545, or Sepolia HTTPS URL (free tier)
LOCAL_RPC=http://127.0.0.1:7545
# Optional alias used by some setups
INFURA_URL=
SEPOLIA_RPC_URL=

# Gmail SMTP (use an App Password, not your normal password)
# https://support.google.com/accounts/answer/185833
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your-app-password

# CORS: frontend origin (Vite default)
FRONTEND_ORIGIN=http://localhost:5173
